{
  "name": "@jayeshbansal/apitype",
  "version": "0.2.0",
  "description": "Generate TypeScript types, Zod schemas, TypeBox, and JSON Schema from any API endpoint or JSON — instantly. Works as a CLI, MCP server, Vite plugin, and GitHub Action.",
  "keywords": [
    "typescript",
    "zod",
    "typebox",
    "json-schema",
    "api",
    "types",
    "codegen",
    "code-generation",
    "json",
    "cli",
    "mcp",
    "model-context-protocol",
    "vite-plugin",
    "developer-tools",
    "type-generation",
    "schema",
    "openapi"
  ],
  "homepage": "https://github.com/jayesh-bansal/apitype",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayesh-bansal/apitype.git"
  },
  "bugs": {
    "url": "https://github.com/jayesh-bansal/apitype/issues"
  },
  "license": "MIT",
  "author": "Jayesh Bansal",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "bin": {
    "apitype": "dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
